# Example environment file for digital-arbitrage.
#
# Copy this file to `.env` (which is gitignored) and fill in real values, then
# load it into your shell before running a live scan, e.g.:
#
#   set -a; source .env; set +a
#
# NEVER commit `.env` or real credentials. Secrets are read only from the
# environment - never from a config file, the repository, or CI.

# --- eBay Browse (OAuth 2.0 client-credentials) ---------------------------- #
EBAY_CLIENT_ID=your-ebay-app-client-id
EBAY_CLIENT_SECRET=your-ebay-app-client-secret

# --- StockX (API key + OAuth 2.0 client-credentials) ----------------------- #
STOCKX_API_KEY=your-stockx-api-key
STOCKX_CLIENT_ID=your-stockx-client-id
STOCKX_CLIENT_SECRET=your-stockx-client-secret
